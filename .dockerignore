# ── Virtual environment (reinstalled inside container from requirements.txt) ──
.venv/
venv/
env/

# ── Git history ───────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/

# ── Secrets (never bake into image) ──────────────────────────────────────────
.env
*.env
.env.*
!.env.example

# ── Logs + temp files ────────────────────────────────────────────────────────
*.log
nohup.out
*.out

# ── Dev / editor files ────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# ── Docs (not needed at runtime; also shrinks the build context sent to the
#    Docker daemon before the build even starts) ─────────────────────────────
README.md
README*.md
*.md
docs/

# ── Tests / dev tooling / non-runtime scripts ────────────────────────────────
tests/
scripts/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Session/patch artifacts (never part of the runtime image) ───────────────
*.tar.gz
.claude/

# ── Test data ────────────────────────────────────────────────────────────────
te.text
